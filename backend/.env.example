# Backend Environment Variables
# Copy this to .env and fill in real values for local dev.

# ---------------------------------------------------------------------------
# LLM (TIP.AI / LiteLLM proxy)
# ---------------------------------------------------------------------------
# Set USE_MOCK_LLM=true to skip live LLM calls and use seeded fixtures.
# Demo-safe default is true so the app boots without keys.
USE_MOCK_LLM=true

# Required only when USE_MOCK_LLM=false
LITELLM_BASE_URL=https://d1t4hkdc2i746c.cloudfront.net
LITELLM_API_KEY=
LITELLM_MODEL=us.anthropic.claude-sonnet-4-6
# Some models (e.g. claude-opus-4-7) reject the temperature param; leave blank to omit it.
LITELLM_TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# Weather (OpenWeatherMap, free tier — https://openweathermap.org/api)
# ---------------------------------------------------------------------------
# Leave blank to use a deterministic mock forecast.
OPENWEATHER_API_KEY=

# ---------------------------------------------------------------------------
# CORS — comma-separated origins
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Session signing key (mock auth — change for any non-demo deployment)
# ---------------------------------------------------------------------------
SESSION_SECRET=bonvoy-demo-session-secret-change-me

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
DEBUG=true
# Path to seed JSON files, relative to where uvicorn is launched.
SEEDS_PATH=../data/seeds
