# Frontend Environment Variables
# Copy this to .env.local and fill in real values

# Mapbox (required for Local Partner Map)
# Get free token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Active persona for demo (alex | jordan | sam)
NEXT_PUBLIC_DEFAULT_PERSONA=alex
